# Persistence. Without DATABASE_URL the app uses an in-memory development store.
#
# Local PostgreSQL:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zoom_task_bot
#
# Supabase Direct (migration / local dev) — Dashboard > Project Settings > Database:
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres
#
# Supabase Transaction Pooler (Vercel / serverless, port 6543):
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true
#
# zoom-task-bot project ref: utvzoegrwkbolxrdflta
DATABASE_URL=

# Required to store API keys registered from chat.
# Generate with: openssl rand -base64 32
KEY_ENCRYPTION_SECRET=

# Optional environment-managed AI keys. Comma-separated plural variables work too.
OPENAI_API_KEY=
OPENAI_API_KEYS=
GEMINI_API_KEY=
GEMINI_API_KEYS=
ANTHROPIC_API_KEY=
ANTHROPIC_API_KEYS=

# Default models can be overridden per Zoom account with chat commands.
OPENAI_MODEL=gpt-5-mini
GEMINI_MODEL=gemini-3.5-flash
ANTHROPIC_MODEL=claude-sonnet-4-6
AI_REQUEST_TIMEOUT_MS=45000
APP_TIME_ZONE=Asia/Tokyo

# Restrict AI configuration commands to these Zoom user IDs.
# Leave empty to allow any account member in a direct message to the bot.
AI_CONFIG_ADMIN_USER_IDS=

# Zoom Chatbot app credentials.
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_BOT_JID=
ZOOM_WEBHOOK_SECRET_TOKEN=

# Zoom Tasks access. Prefer a separate Server-to-Server OAuth app.
ZOOM_TASKS_ACCOUNT_ID=
ZOOM_TASKS_CLIENT_ID=
ZOOM_TASKS_CLIENT_SECRET=
# Optional fixed token for local testing only.
ZOOM_TASKS_ACCESS_TOKEN=

# Protect POST /api/internal/extract-tasks.
INTERNAL_API_TOKEN=
